{
  "name": "@forestdream/mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@forestdream/shared": "workspace:*",
    "@forestdream/eurobase-client": "workspace:*",
    "snore-detector": "link:./modules/snore-detector",
    "expo-constants": "~17.0.3",
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "expo-av": "~15.0.0",
    "expo-task-manager": "~12.0.0",
    "expo-notifications": "~0.29.0",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-keep-awake": "~14.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-iap": "^12.15.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "victory-native": "^41.0.0",
    "zustand": "^4.5.0",
    "@tanstack/react-query": "^5.51.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/react": "~18.3.12",
    "vitest": "^2.0.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": ["@forestdream/shared", "@forestdream/eurobase-client", "snore-detector", "expo-av"],
        "listUnknownPackages": false
      }
    }
  }
}
