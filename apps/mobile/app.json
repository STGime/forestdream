{
  "expo": {
    "name": "ForestDream",
    "slug": "forestdream",
    "scheme": "forestdream",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.eurobase.forestdream",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "ForestDream listens for snoring so it can respond with soothing sounds. All audio is processed on your device and is never recorded, stored, or uploaded."
      }
    },
    "android": {
      "package": "app.eurobase.forestdream",
      "permissions": ["RECORD_AUDIO", "FOREGROUND_SERVICE", "FOREGROUND_SERVICE_MEDIA_PLAYBACK", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      "expo-router",
      ["expo-av", { "microphonePermission": "ForestDream uses your microphone on-device to detect disturbances. Audio is never recorded or uploaded." }],
      "./plugins/with-iap-play-flavor"
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "EUROBASE_URL": "https://forestdream.eurobase.app",
      "EUROBASE_PUBLIC_KEY": "eb_pk_79b80f5ca7de58c4d919748e4ae85cdd",
      "API_BASE": "https://forestdream-api.eurobase.app"
    }
  }
}
